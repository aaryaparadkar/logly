# Database
DATABASE_URL=postgresql://user:password@localhost:5432/logly

# Encryption (generate with: openssl rand -base64 32)
ENCRYPTION_SECRET=your-32-character-secret-key-here

# AI (Mistral)
MISTRAL_API_KEY=your-mistral-api-key

# App Configuration
LOGLY_BASE_URL=http://localhost:3000
PORT=3000

# Optional: GitHub App Token (for higher rate limits)
# GITHUB_TOKEN=your-github-token

# Optional: AI Model (defaults to mistral-small-latest)
# AI_MODEL=mistral-small-latest
